{
  "manifest_version": 3,
  "name": "Project Manager",
  "version": "0.1.0",
  "description": "簡易的GitHub issue專案管理工具",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Project Manager"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "host_permissions": [
    "https://api.github.com/*"
  ]
}